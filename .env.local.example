# Convex URL (optional for local realtime)
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# Cloud-ready source mode
# ingest (default): production-safe, no local FS dependency
# local: enables /api/workspace local file inspection endpoints
SOURCE_MODE=ingest

# Ingest auth token for POST /api/ingest
INGEST_AUTH_TOKEN=change_me_with_a_long_random_value

# Local-only workspace path (used only when SOURCE_MODE=local)
WORKSPACE_PATH=/Users/yourname/.openclaw/workspace
